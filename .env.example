# ──────────────────────────────────────────────
# Auth — Clerk (https://clerk.com)
# ──────────────────────────────────────────────
VITE_CLERK_PUBLISHABLE_KEY=pk_live_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ──────────────────────────────────────────────
# AI Agent — Anthropic
# ──────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ──────────────────────────────────────────────
# YouTube Data API v3
# Google Cloud Console → APIs & Services → Credentials
# Also enable "YouTube Data API v3" in the library
# ──────────────────────────────────────────────
YOUTUBE_API_KEY=AIzaSyXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
YOUTUBE_CHANNEL_ID=UCxxxxxxxxxxxxxxxxxxxx

# ──────────────────────────────────────────────
# X / Twitter API v2
# developer.twitter.com → Project → Bearer Token (read-only)
# ──────────────────────────────────────────────
TWITTER_BEARER_TOKEN=AAAAAAAAAAAAAAAAAAAAAxxxxxxxxxxxxxxxxxxxxxxxx
TWITTER_USERNAME=your_twitter_handle

# ──────────────────────────────────────────────
# Instagram Graph API
# Requires Facebook Developer App + Business account
# Get a long-lived User Access Token with instagram_basic, read_insights
# ──────────────────────────────────────────────
INSTAGRAM_USER_TOKEN=EAAxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
INSTAGRAM_USER_ID=17841400000000000

# ──────────────────────────────────────────────
# TikTok Business API
# business-api.tiktok.com → App → Access Token
# ──────────────────────────────────────────────
TIKTOK_ACCESS_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TIKTOK_ADVERTISER_ID=0000000000000

# ──────────────────────────────────────────────
# LinkedIn Marketing API
# developer.linkedin.com → App → OAuth 2.0 access token
# Scopes: r_organization_social, r_organization_followers
# ──────────────────────────────────────────────
LINKEDIN_ACCESS_TOKEN=AQxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
LINKEDIN_ORG_ID=00000000
